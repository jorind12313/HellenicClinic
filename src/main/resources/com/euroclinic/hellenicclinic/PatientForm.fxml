<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.euroclinic.hellenicclinic.controller.PatientController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Label styleClass="header-label" text="Patient Form">
         <font>
            <Font name="System Bold" size="30.0" />
         </font>
      </Label>
      <Label graphicTextGap="10.0" text="Patient Name: " />
      <TextField fx:id="nameField" alignment="TOP_LEFT" nodeOrientation="LEFT_TO_RIGHT" prefHeight="0.0" prefWidth="310.0" />
      <Label alignment="TOP_LEFT" graphicTextGap="5.0" nodeOrientation="RIGHT_TO_LEFT" text="Phone Number:" />
      <TextField fx:id="phoneField" alignment="TOP_LEFT" prefHeight="25.0" prefWidth="138.0" />
      <Label alignment="TOP_CENTER" contentDisplay="RIGHT" graphicTextGap="10.0" prefHeight="17.0" prefWidth="112.0" text="Medical History:" />
      <TextField fx:id="historyField" alignment="TOP_LEFT" nodeOrientation="LEFT_TO_RIGHT" prefHeight="0.0" prefWidth="310.0" />
      <Button mnemonicParsing="false" onAction="#handleSavePatient" prefHeight="35.0" prefWidth="71.0" text="Add" />
   </children>

</VBox>
