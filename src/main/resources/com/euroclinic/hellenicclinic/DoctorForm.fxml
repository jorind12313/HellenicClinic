<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.euroclinic.hellenicclinic.controller.DoctorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label styleClass="header-label" text="Doctor Form">
        <font>
            <Font name="System Bold" size="30.0" />
        </font>
    </Label>

    <Label text="Doctor Name:" />
    <TextField fx:id="nameField" />

    <Label text="Specialty:" />
    <TextField fx:id="specialtyField" />

    <Label text="Phone Number:" />
    <TextField fx:id="phoneField" />

    <Button mnemonicParsing="false" onAction="#handleSaveDoctor" text="Add Doctor" />

</VBox>
